# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Database ---
# Local dev/tests use the embedded Postgres started by `pnpm db:dev` (port 54329):
DATABASE_URL=postgresql://postgres:postgres@localhost:54329/postgres
# In production, point this at Supabase (Project Settings -> Database -> Connection string,
# the DIRECT connection on port 5432 for a long-running worker) and turn SSL on:
# DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
DATABASE_SSL=false   # set to "true" (or "require") in production — Supabase requires TLS

# --- Secrets ---
VIGIL_SECRET_KEY=dev-only-change-me        # used to encrypt stored app credentials
OPENROUTER_API_KEY=sk-or-...               # LLM provider (mapping only); not needed for check/sweep
# VIGIL_MAP_MODEL=anthropic/claude-sonnet-4.5   # optional model override

# --- Screenshot storage (optional) ---
# Leave all three unset to store screenshots on local disk (default; used in dev/tests).
# Set all three to upload screenshots to Supabase Storage in production:
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SERVICE_KEY=<service-role key — server-side only, never ship to the browser>
# SUPABASE_SCREENSHOT_BUCKET=screenshots
